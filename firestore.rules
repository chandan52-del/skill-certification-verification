rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
    
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isAdmin() { 
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'; 
    }
    
    match /users/{userId} {
      function isValidUser(data) {
        return data.name is string && data.name.size() <= 100
            && data.email is string && data.email.size() <= 100
            && data.role is string && data.role in ['student', 'institute', 'employer', 'admin']
            && (data.keys().hasAll(['name', 'email', 'role']));
      }
      allow read: if true; // Public profiles for certificate validation
      allow create: if isSignedIn() && request.auth.uid == userId && isValidUser(incoming());
      allow update: if isSignedIn() && request.auth.uid == userId && isValidUser(incoming());
    }

    match /institutes/{instituteId} {
      allow read: if true;
      allow write: if isSignedIn(); // Simplify for demo
    }

    match /skills/{skillId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /certificates/{certificateId} {
      allow read: if true;
      allow write: if isSignedIn(); // Simplify for demo
    }

    match /verificationLogs/{logId} {
      allow read: if isSignedIn();
      allow create: if true; // public verifications
    }
  }
}
